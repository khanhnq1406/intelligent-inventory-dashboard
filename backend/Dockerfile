# Build stage
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /server ./cmd/server/

# Run stage
FROM alpine:3.19
RUN adduser -D appuser
COPY --from=builder /server /server
COPY --from=builder /app/migrations/ /migrations/
USER appuser
EXPOSE 8080
CMD ["/server"]
